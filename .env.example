# Hugging Face Token (required for model downloads)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily API Key (required for web search functionality)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (optional, only used for RAGAS evaluation)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SEC Email (required for SEC EDGAR downloads - must be a valid email)
SEC_EMAIL=your-email@example.com

# Model Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
DEVICE=cuda  # or 'cpu' if no GPU available

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3

# Vector Database
VECTOR_DB_TYPE=chroma  # chroma or faiss
