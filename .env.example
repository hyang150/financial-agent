# =============================================================================
# Finance Agent — copy to ".env" and fill in real values (never commit .env)
# 说明见 README.md「环境变量」一节
# =============================================================================

# --- Required for main.py / Hugging Face models ---
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Strongly recommended for SEC downloads (ingestion.py) ---
SEC_EMAIL=your-email@example.com

# --- Optional: web search tool (Tavily) ---
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: RAGAS / OpenAI-compatible API (not wired in repo yet) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Defaults / documentation (main.py often uses CLI flags) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_MODEL=Qwen/Qwen3-8B
DEVICE=cuda

CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3

VECTOR_DB_TYPE=chroma
